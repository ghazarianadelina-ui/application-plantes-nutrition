generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url=env("DATABASE_URL")
}

model Utilisateur {
  id_utilisateur     Int      @id @default(autoincrement())
  nom                String
  prenom             String
  email              String   @unique
  mot_de_passe       String
  role               String
  date_inscription   DateTime @default(now())
  statut             String

  contenus           Contenu[]
  abonnements        Abonnement[]
  dons               Don[]
  inscriptions       InscriptionAtelier[]
}

model Contenu {
  id_contenu         Int      @id @default(autoincrement())
  titre              String
  description        String
  rubrique           String
  premium            Boolean  @default(false)
  date_publication   DateTime @default(now())
  path               String
  id_utilisateur_admin Int

  admin Utilisateur @relation(fields: [id_utilisateur_admin], references: [id_utilisateur])
}

model Abonnement {
  id_abonnement      Int      @id @default(autoincrement())
  type_formule       String
  prix               Float
  date_debut         DateTime
  date_fin           DateTime?
  statut             String
  id_utilisateur     Int

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur])
  paiements   Paiement[]
}

model Atelier {
  id_atelier         Int      @id @default(autoincrement())
  titre              String
  description        String
  date_atelier       DateTime
  lieu               String
  nombre_places      Int
  prix               Float

  inscriptions       InscriptionAtelier[]
}

model InscriptionAtelier {
  id_inscription     Int      @id @default(autoincrement())
  date_inscription   DateTime @default(now())
  statut             String
  id_utilisateur     Int
  id_atelier         Int

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur])
  atelier     Atelier     @relation(fields: [id_atelier], references: [id_atelier])
  paiements   Paiement[]

  @@unique([id_utilisateur, id_atelier])
}

model Don {
  id_don             Int      @id @default(autoincrement())
  montant            Float
  date_don           DateTime @default(now())
  type_don           String
  id_utilisateur     Int

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur])
  paiements   Paiement[]
}

model Paiement {
  id_paiement        Int      @id @default(autoincrement())
  reference_paiement String   @unique
  montant            Float
  date_paiement      DateTime @default(now())
  statut             String

  id_abonnement      Int?
  id_inscription     Int?
  id_don             Int?

  abonnement   Abonnement?         @relation(fields: [id_abonnement], references: [id_abonnement])
  inscription  InscriptionAtelier? @relation(fields: [id_inscription], references: [id_inscription])
  don          Don?                @relation(fields: [id_don], references: [id_don])
}