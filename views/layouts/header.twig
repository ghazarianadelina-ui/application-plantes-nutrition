<header>
    <nav style="display:flex; gap:1rem; align-items:center; padding:1rem; background:#f4f4f4;">

        <!-- Liens publics -->
        <a href="/">Accueil</a>
        <a href="/contenus">Contenus</a>
        <a href="/ateliers">Ateliers</a>
        <a href="/abonnement">Abonnement</a>
        <a href="/don">Don</a>

        {% if currentUser %}
            <!-- Utilisateur connecté -->
            <a href="/profil">Mon profil</a>

            <!-- ADMIN -->
            {% if currentUser.role == 'admin' %}
                <a href="/admin" style="color:green; font-weight:bold;">Dashboard Admin</a>
                <a href="/admin/contenus">Contenus</a>
                <a href="/admin/ateliers">Ateliers</a>
                <a href="/admin/utilisateurs">Utilisateurs</a>
                <a href="/admin/paiements">Paiements</a>
            {% endif %}

            <a href="/deconnexion" style="color:red;">Déconnexion</a>

        {% else %}
            <!-- Non connecté -->
            <a href="/connexion">Connexion</a>
            <a href="/inscription">Inscription</a>
        {% endif %}

    </nav>
</header>